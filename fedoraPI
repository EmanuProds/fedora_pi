    "evince"
    "totem"
)

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $*" | tee -a "$LOG_FILE"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*" | tee -a "$LOG_FILE"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $*" | tee -a "$LOG_FILE"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*" | tee -a "$LOG_FILE" >&2
}

log_debug() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "${BLUE}[DEBUG]${NC} $*" | tee -a "$LOG_FILE"
    fi
}

# Error handling
error_exit() {
    log_error "$*"
    echo -e "\n${RED}Script failed. Check $LOG_FILE for details.${NC}"
    exit 1
}

# Check if running as root
check_root() {
    if [[ $EUID -eq 0 ]]; then
        error_exit "This script should not be run as root. Please run as a regular user with sudo access."
    fi
}

# Check bash version
check_bash_version() {
    if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
        error_exit "This script requires Bash $MIN_BASH_VERSION or higher. Current version: $BASH_VERSION"
    fi
}

# Check internet connectivity
check_internet() {
    if ! ping -c 1 -W 2 8.8.8.8 &>/dev/null; then
        error_exit "No internet connection detected. Please check your network settings."
    fi
}

# Check and install dialog if not present
check_dialog() {
    if ! command -v dialog &>/dev/null; then
        log_info "Dialog not found. Installing dialog for better user interface..."

        if ! sudo dnf install -y dialog; then
            log_warn "Failed to install dialog. Falling back to basic text interface."
            return 1
        fi

        log_success "Dialog installed successfully"
    fi

    return 0
}

# ============================================================================
# FEDORA VERSION DETECTION AND CONFIGURATION
# ============================================================================

detect_fedora_version() {
    log_info "Detecting Fedora version..."

    if [[ ! -f /etc/os-release ]]; then
        error_exit "Cannot find /etc/os-release file. This doesn't appear to be a Fedora system."
    fi

    # Source the os-release file
    # shellcheck disable=SC1091
    . /etc/os-release

    FEDORA_VERSION="${VERSION_ID:-unknown}"
    FEDORA_NAME="${NAME:-unknown}"

    if [[ "$FEDORA_VERSION" == "unknown" ]]; then
        error_exit "Unable to detect Fedora version from /etc/os-release"
    fi

    log_success "Detected: $FEDORA_NAME $FEDORA_VERSION"
}

configure_version_specifics() {
    log_info "Configuring version-specific settings for Fedora $FEDORA_VERSION..."

    # Dynamic repository URLs based on detected version
    readonly RPMFUSION_FREE="https://download1.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VERSION}.noarch.rpm"
    readonly RPMFUSION_NONFREE="https://download1.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VERSION}.noarch.rpm"
    readonly CODE_REPO_URL="https://packages.microsoft.com/yumrepos/vscode"

    # Version-specific package adjustments
    case "${FEDORA_VERSION}" in
        "39"|"40"|"41")
            log_warn "Fedora $FEDORA_VERSION detected. Some features may be limited."
            readonly EXTRA_PACKAGES=("libxcrypt-compat" "python3-pip")
            ;;
        "42"|*)
            readonly EXTRA_PACKAGES=()
            ;;
    esac
}

validate_repositories() {
    log_info "Validating repository availability..."

    local repos_valid=true

    # Test RPM Fusion Free
    if ! curl -s --max-time 10 --head "$RPMFUSION_FREE" | head -n 1 | grep -q "200"; then
        log_warn "RPM Fusion Free repository not available for Fedora $FEDORA_VERSION"
        repos_valid=false
    fi

    # Test RPM Fusion Non-Free
    if ! curl -s --max-time 10 --head "$RPMFUSION_NONFREE" | head -n 1 | grep -q "200"; then
        log_warn "RPM Fusion Non-Free repository not available for Fedora $FEDORA_VERSION"
        repos_valid=false
    fi

    if [[ "$repos_valid" == false ]]; then
        log_warn "Some repositories may not be available. Continuing with available repositories only."
    fi
}

# ============================================================================
# INSTALLATION FUNCTIONS
# ============================================================================

install_system_updates() {
    log_info "Updating system packages..."

    if ! sudo dnf upgrade --refresh -y; then
        error_exit "Failed to update system packages"
    fi

    log_success "System packages updated successfully"
}

remove_bloatware() {
    log_info "Removing bloatware packages..."

    local packages_to_remove=()
    for package in "${BLOATWARE_PACKAGES[@]}"; do
        if rpm -q "$package" &>/dev/null; then
            packages_to_remove+=("$package")
        fi
    done

    if [[ ${#packages_to_remove[@]} -eq 0 ]]; then
        log_info "No bloatware packages found to remove"
        return 0
    fi

    log_info "Removing: ${packages_to_remove[*]}"

    if ! sudo dnf remove -y "${packages_to_remove[@]}"; then
        log_warn "Some bloatware packages could not be removed"
    else
        log_success "Bloatware packages removed successfully"
    fi
}

install_system_packages() {
    log_info "Installing system packages..."

    local all_packages=("${SYSTEM_PACKAGES[@]}" "${EXTRA_PACKAGES[@]}")

    if ! sudo dnf install -y "${all_packages[@]}"; then
        error_exit "Failed to install system packages"
    fi

    log_success "System packages installed successfully"
}

setup_repositories() {
    log_info "Setting up additional repositories..."

    # Microsoft VS Code repository
    log_info "Adding Microsoft VS Code repository..."
    sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc

    cat << EOF | sudo tee /etc/yum.repos.d/vscode.repo > /dev/null
[code]
name=Visual Studio Code
baseurl=$CODE_REPO_URL
enabled=1
gpgcheck=1
gpgkey=https://packages.microsoft.com/keys/microsoft.asc
EOF

    # RPM Fusion repositories (if available)
    if curl -s --max-time 5 --head "$RPMFUSION_FREE" | head -n 1 | grep -q "200"; then
        log_info "Adding RPM Fusion Free repository..."
        sudo dnf install -y "$RPMFUSION_FREE" || log_warn "Failed to add RPM Fusion Free"
    fi

    if curl -s --max-time 5 --head "$RPMFUSION_NONFREE" | head -n 1 | grep -q "200"; then
        log_info "Adding RPM Fusion Non-Free repository..."
        sudo dnf install -y "$RPMFUSION_NONFREE" || log_warn "Failed to add RPM Fusion Non-Free"
    fi

    # COPR repositories
    log_info "Adding COPR repositories..."
    sudo dnf copr enable -y psygreg/linuxtoys || log_warn "Failed to enable linuxtoys COPR"

    log_success "Repository setup completed"
}

install_fonts() {
    log_info "Installing development fonts..."

    if ! sudo dnf install -y "${FONT_PACKAGES[@]}"; then
        error_exit "Failed to install fonts"
    fi

    log_success "Fonts installed successfully"
}

setup_flatpak() {
    log_info "Setting up Flatpak and Flathub..."

    # Add Flathub repository
    if ! flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo; then
        log_warn "Failed to add Flathub repository"
        return 1
    fi

    log_success "Flathub repository added successfully"
}

install_flatpak_apps() {
    log_info "Installing Flatpak applications..."

    if ! flatpak install flathub -y "${FLATPAK_APPS[@]}"; then
        log_warn "Some Flatpak applications failed to install"
    else
        log_success "Flatpak applications installed successfully"
    fi
}

install_development_tools() {
    log_info "Installing development tools and applications..."

    if ! sudo dnf install -y "${DEV_PACKAGES[@]}"; then
        error_exit "Failed to install development tools"
    fi

    log_success "Development tools installed successfully"
}

