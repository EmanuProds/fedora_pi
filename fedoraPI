# ============================================================================
# MAIN FUNCTION
# ============================================================================

main() {
    # Initialize logging
    echo "Fedora Post-Installation Script v$SCRIPT_VERSION - $(date)" > "$LOG_FILE"
    log_info "Starting Fedora Post-Installation Script v$SCRIPT_VERSION"

    # Pre-flight checks
    check_root
    check_bash_version
    check_internet
    check_dialog

    # Version detection and configuration
    detect_fedora_version
    configure_version_specifics
    validate_repositories

    # Show banner and menu
    show_banner

    # Set up cleanup trap
    trap cleanup EXIT

    # Run main menu
    show_main_menu
}

# Run main function with all arguments
main "$@"
