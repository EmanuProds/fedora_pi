#!/bin/bash
#
# Fedora Post-Installation Script
# Modern, interactive post-installation setup for Fedora Linux
#
# Author:        Emanuel Pereira
# Website:       https://fedoraproject.org/
# Repository:    https://github.com/EmanuProds/post-installation_fedora
# License:       MIT
#
# Description:
# This script provides a modern, interactive way to set up a Fedora Linux
# workstation with development tools, multimedia applications, and system
# optimizations. It automatically detects the Fedora version and adapts
# configurations accordingly.
#
# Features:
# - Automatic Fedora version detection
# - Interactive menu system
# - Comprehensive error handling and logging
# - Modern package management with DNF and Flatpak
# - Development tools and fonts
# - System cleanup and optimization
#
# Tested on:
# - Fedora 42 Workstation
# - Fedora 43 Workstation (future compatibility)
#
# Usage:
#   chmod +x fedoraPI.sh
#   ./fedoraPI.sh
#
# ------------------------------------------------------------------------ #

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================

# Script metadata
readonly SCRIPT_NAME="Fedora Post-Installation Script"
readonly SCRIPT_VERSION="2.0.0"
readonly SCRIPT_AUTHOR="Emanuel Pereira"
readonly MIN_BASH_VERSION="4.0"

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

# Logging
readonly LOG_FILE="/tmp/fedora_pi_$(date +%Y%m%d_%H%M%S).log"
readonly VERBOSE="${VERBOSE:-false}"

# Fedora version detection
FEDORA_VERSION=""
FEDORA_NAME=""

# ============================================================================
# PACKAGE LISTS
# ============================================================================

# System packages to install
readonly SYSTEM_PACKAGES=(
    "dialog"
    "cabextract"
    "lzip"
    "p7zip"
    "p7zip-plugins"
    "unrar"
    "gnome-tweaks"
    "file-roller"
    "openssl"
    "gnome-shell-extension-appindicator"
    "gnome-shell-extension-caffeine"
    "gnome-shell-extension-gsconnect"
)

# Font packages
readonly FONT_PACKAGES=(
    "fira-code-fonts"
    "jetbrains-mono-fonts-all"
)

# Development and application packages
readonly DEV_PACKAGES=(
    "code"
    "gparted"
    "gamemode"
    "npm"
    "git"
    "decibels"
    "papers"
