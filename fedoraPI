# ============================================================================

run_system_update_cleanup() {
    dialog --title "System Update & Cleanup" \
           --yesno "This will:\n\n‚ÄĘ Update system packages\n‚ÄĘ Remove bloatware\n‚ÄĘ Install system packages\n‚ÄĘ Setup additional repositories\n\nContinue?" \
           12 50

    if [[ $? -ne 0 ]]; then
        return 1
    fi

    # Show progress
    (
        echo "10" ; sleep 0.5
        install_system_updates
        echo "30" ; sleep 0.5
        remove_bloatware
        echo "50" ; sleep 0.5
        install_system_packages
        echo "80" ; sleep 0.5
        setup_repositories
        echo "100" ; sleep 0.5
    ) | dialog --title "System Update & Cleanup" \
               --gauge "Processing..." 8 50 0

    dialog --title "Success" \
           --msgbox "System update and cleanup completed successfully!" \
           6 50
}

run_complete_setup() {
    dialog --title "Complete Setup" \
           --yesno "This will install ALL components:\n\n‚ÄĘ System updates & cleanup\n‚ÄĘ Development fonts\n‚ÄĘ Development tools\n‚ÄĘ Flatpak & applications\n\nThis may take several minutes.\n\nContinue?" \
           14 60

    if [[ $? -ne 0 ]]; then
        return 1
    fi

    # Show progress for complete setup
    (
        echo "5" ; sleep 0.5
        install_system_updates
        echo "15" ; sleep 0.5
        remove_bloatware
        echo "25" ; sleep 0.5
        install_system_packages
        echo "35" ; sleep 0.5
        setup_repositories
        echo "45" ; sleep 0.5
        install_fonts
        echo "60" ; sleep 0.5
        setup_flatpak
        echo "75" ; sleep 0.5
        install_flatpak_apps
        echo "90" ; sleep 0.5
        install_development_tools
