show_main_menu() {
    while true; do
        local choice
        choice=$(dialog --clear \
                        --title "Fedora Post-Installation Script v$SCRIPT_VERSION" \
                        --menu "\nDetected: $FEDORA_NAME $FEDORA_VERSION\n\nChoose an option:" \
                        20 70 10 \
                        1 "System Update & Cleanup" \
                        2 "Install Fonts" \
                        3 "Install Development Tools" \
                        4 "Setup Flatpak & Install Apps" \
                        5 "Run Complete Setup (All components)" \
                        6 "Exit" \
                        2>&1 >/dev/tty)

        local exit_code=$?
        clear

        # Check if user pressed Cancel/Escape
        if [[ $exit_code -ne 0 ]]; then
            log_info "User cancelled. Exiting..."
            exit 0
        fi

        case $choice in
            1)
                run_system_update_cleanup
                ;;
            2)
                dialog --title "Install Fonts" \
                       --yesno "Install development fonts?\n\n‚ÄĘ Fira Code\n‚ÄĘ JetBrains Mono" \
                       8 40
                [[ $? -eq 0 ]] && install_fonts && \
                dialog --title "Success" --msgbox "Fonts installed successfully!" 6 40
                ;;
            3)
                dialog --title "Install Development Tools" \
                       --yesno "Install development tools?\n\n‚ÄĘ VS Code\n‚ÄĘ Git, Node.js\n‚ÄĘ GParted, etc." \
                       8 40
                [[ $? -eq 0 ]] && install_development_tools && \
                dialog --title "Success" --msgbox "Development tools installed successfully!" 6 40
                ;;
            4)
                dialog --title "Setup Flatpak & Apps" \
                       --yesno "Setup Flatpak and install apps?\n\n‚ÄĘ Extension Manager\n‚ÄĘ Flatseal\n‚ÄĘ DBeaver, etc." \
                       8 40
                [[ $? -eq 0 ]] && setup_flatpak && install_flatpak_apps && \
                dialog --title "Success" --msgbox "Flatpak and applications installed successfully!" 6 40
                ;;
            5)
                run_complete_setup
                ;;
            6)
                log_info "Exiting..."
                exit 0
                ;;
            *)
                dialog --title "Error" --msgbox "Invalid option selected." 6 40
                ;;
        esac
    done
}

# ============================================================================
